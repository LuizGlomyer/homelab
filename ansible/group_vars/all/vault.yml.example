# Hosts credentials and secrets
vault_nas_admin_password: "your_credentials"
vault_nas_shared_files_password: "your_credentials"
vault_nas_navidrome_password: "your_credentials"
vault_nas_jellyfin_password: "your_credentials"
vault_nas_metube_password: "your_credentials"
vault_smb_proxmox_password: "your_credentials"


# Services credentials and secrets
vault_caddy_cloudflare_token: "your_credentials"
vault_caddy_duckdns_token: "your_credentials"
vault_caddy_dns_email: "your_credentials"

vault_navidrome_lastfm_api_key: "your_credentials"
vault_navidrome_lastfm_shared_secret: "your_credentials"

vault_olivetin_user_password: "your_credentials"
vault_vaultwarden_admin_token: "your_credentials"

# Diun notifications
vault_diun_telegram_token: "your_telegram_bot_token"
vault_diun_telegram_chat_ids: "your_chat_id_1,your_chat_id_2"  # Can be multiple IDs separated by commas
vault_diun_discord_webhook_url: "your_discord_webhook_url"

# Docker Hub credentials for Diun registry auth (optional)
vault_dockerhub_username: "your_dockerhub_username"
vault_dockerhub_password: "your_dockerhub_password"
